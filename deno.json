{
	"compilerOptions": {
		"lib": ["deno.window", "deno.ns"]
	},
	"fmt": {
		"useTabs": true,
		"lineWidth": 80,
		"indentWidth": 2,
		"semiColons": false,
		"singleQuote": true,
		"proseWrap": "preserve",
		"include": ["scripts/", "deno.json"]
	},
	"lint": {
		"rules": {
			"tags": ["recommended"],
			"include": [
				"camelcase",
				"eqeqeq",
				"explicit-function-return-type",
				"explicit-module-boundary-types",
				"no-eval",
				"no-sparse-arrays",
				"single-var-declarator",
				"no-non-null-assertion"
			]
		}
	},
	"tasks": {
		"format": "clang-format -i crates/core/src/c/*.c crates/core/src/c/*.h && cargo fmt && deno fmt"
	}
}
